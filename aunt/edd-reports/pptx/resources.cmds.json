","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[2]","type":"picture","props":{"src":"assets/resources_s2_0.png","x":"4.26cm","y":"5.50cm","width":"25.34cm","height":"6.34cm"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Module 5 has several topics. This report covers only the first — 5.1, the principle the rest depend on.","x":"2.2cm","width":"29.47cm","align":"center","y":"12.09cm","height":"1.4cm","size":"14pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"What this report will cover","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  What contextualization means","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  Why it makes learning stick","x":"2.2cm","width":"29.47cm","align":"left","y":"5.80cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  The principles themselves, one by one","x":"2.2cm","width":"29.47cm","align":"left","y":"7.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  How to apply them, with examples and cautions","x":"2.2cm","width":"29.47cm","align":"left","y":"8.80cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"Defining the construct","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"What contextualization means","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"Contextualization","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.2cm","size":"24pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"Designing and adapting learning resources so they connect to the learner's real environment — their place, culture, language, and daily experience.\nIn plain terms: teaching with examples learners already recognize from their own lives.","x":"2.2cm","width":"29.47cm","align":"left","y":"6.60cm","height":"2.8cm","size":"19pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"A close cousin: localization","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Contextualization","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.2cm","size":"24pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Connecting content to the learner's lived experience and setting.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.60cm","height":"2.8cm","size":"19pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Localization","x":"2.2cm","width":"29.47cm","align":"left","y":"8.70cm","height":"1.2cm","size":"24pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Adapting to a specific place — its language, examples, and culture (topic 5.2).","x":"2.2cm","width":"29.47cm","align":"left","y":"10.00cm","height":"2.8cm","size":"19pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"Why context makes learning stick","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"When new ideas are tied to something a learner already knows, they are easier to understand, easier to remember, and easier to use in real life.","x":"2.2cm","width":"29.47cm","align":"left","y":"4.300000000000001cm","height":"13.25cm","size":"26pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"Building on what is already there","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[7]","type":"picture","props":{"src":"assets/resources_s7_0.png","x":"4.26cm","y":"4.50cm","width":"25.34cm","height":"5.32cm"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"Context is the bridge from the familiar to the new.","x":"2.2cm","width":"29.47cm","align":"center","y":"10.07cm","height":"1.4cm","size":"14pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"5.1","x":"2.2cm","width":"29.47cm","align":"left","y":"2.4cm","height":"4cm","size":"96pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"The heart of the topic","x":"2.2cm","width":"29.47cm","align":"left","y":"8.6cm","height":"1.0cm","size":"16pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"The Principles of Contextualization","x":"2.2cm","width":"29.47cm","align":"left","y":"10.0cm","height":"4cm","size":"40pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Principle 1","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Relevance","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Use examples drawn from the learner's own community and surroundings — things they see and do every day.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Principle 2","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Prior knowledge","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Build each new lesson on what learners already understand, so the new idea has something to attach to.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Principle 3","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Authenticity","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Draw on real situations the learner could actually meet — not invented or distant ones.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Principle 4","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Meaning over memorization","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Aim for understanding learners can use in real life, not facts repeated by rote and soon forgotten.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"The four principles at a glance","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"shape","props":{"preset":"rect","fill":"e7c873","line":"none","x":"2.20cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Relevance","x":"2.70cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Examples from their own world.","x":"2.70cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"shape","props":{"preset":"rect","fill":"e7c873","line":"none","x":"17.43cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Prior knowledge","x":"17.93cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Build on what they already know.","x":"17.93cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"shape","props":{"preset":"rect","fill":"e7c873","line":"none","x":"2.20cm","y":"7.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Authenticity","x":"2.70cm","width":"13.73cm","align":"left","y":"7.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Real situations, not invented ones.","x":"2.70cm","width":"13.73cm","align":"left","y":"8.30cm","height":"1.7cm","size":"16pt","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"shape","props":{"preset":"rect","fill":"e7c873","line":"none","x":"17.43cm","y":"7.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Meaning","x":"17.93cm","width":"13.73cm","align":"left","y":"7.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Understanding they can apply.","x":"17.93cm","width":"13.73cm","align":"left","y":"8.30cm","height":"1.7cm","size":"16pt","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"The same lesson, two ways","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[14]","type":"picture","props":{"src":"assets/resources_s14_0.png","x":"2.20cm","y":"4.30cm","width":"14.23cm","height":"6.19cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Abstract — far from the learner's world.","x":"2.20cm","width":"14.23cm","align":"center","y":"10.69cm","height":"1.4cm","size":"13pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[14]","type":"picture","props":{"src":"assets/resources_s14_1.png","x":"17.43cm","y":"4.30cm","width":"14.23cm","height":"6.19cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Contextualized — the same math, made local.","x":"17.43cm","width":"14.23cm","align":"center","y":"10.69cm","height":"1.4cm","size":"13pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"Contextualizing across subjects","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"◆  Math","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"     Counting with sari-sari store prices instead of textbook coins.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"◆  Science","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"     Studying weather using the local rainy and dry seasons.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"◆  Reading","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"     Stories set in places and traditions the learners know.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"Applying the principle","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"1.  Know your learners","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"      Their place, language, work, and experiences.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"2.  Find local examples","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"      Swap distant references for familiar ones.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"3.  Adapt, don't dilute","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"      Keep the standard; change only the wrapping.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"One important caution","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[17]","type":"shape","props":{"preset":"roundRect","fill":"2e211b","line":"none","x":"2.2cm","y":"4.30cm","width":"29.47cm","height":"13.25cm"}},{"op":"add","path":"/slide[17]","type":"shape","props":{"preset":"rect","fill":"e8915a","line":"none","x":"2.2cm","y":"4.30cm","width":"0.18cm","height":"13.25cm"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"Adapt, never lower","x":"2.80cm","width":"28.27cm","align":"left","y":"4.80cm","height":"0.9cm","size":"14pt","bold":"true","color":"e7c873","font":"Verdana"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"Contextualizing changes the examples, not the standard. The learning goal stays exactly as high — we only make the path to it more familiar.","x":"2.80cm","width":"28.27cm","align":"left","y":"5.90cm","height":"11.25cm","size":"21pt","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"241410"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"Why contextualization matters","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8915a","font":"Verdana"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  Engagement","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     Learners pay attention to what feels relevant.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  Comprehension","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"f6efe7","font":"Verdana"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     Familiar context lowers the barrier to new ideas.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"cdb6a6","font":"Verdana"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  Equity","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true"