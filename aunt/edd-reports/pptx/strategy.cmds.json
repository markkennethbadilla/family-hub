24a","font":"Georgia"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"1.  Identify who you serve","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"      Name the people who benefit.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"2.  State what you do for them","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"      The core service or change you provide.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"3.  Explain why it matters","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"      The deeper value behind the work.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"4.  Draft, then trim","x":"2.2cm","width":"29.47cm","align":"left","y":"12.10cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"      Write it out, then cut to the essential.","x":"2.2cm","width":"29.47cm","align":"left","y":"13.10cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","prop