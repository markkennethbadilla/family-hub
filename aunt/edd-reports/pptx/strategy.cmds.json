 Names the real reason the organization exists.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"◆  Distinctive","x":"2.2cm","width":"29.47cm","align":"left","y":"12.10cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"     Fits this organization, not just any organization.","x":"2.2cm","width":"29.47cm","align":"left","y":"13.10cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"07241d"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Why defining purpose comes first","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e7b24a","font":"Georgia"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"◆  Alignment","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"     Keeps everyone pulling in the same direction.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"◆  Decision filter","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"f3f1ea","font":"Calibri"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"     Guides day-to-day choices when priorities compete.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"aebfb6","font":"Calibri"}},{"op":"add","path":"/slide[10]"