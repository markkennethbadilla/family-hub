[{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Cebu Technological University · Doctor of Education (EdD)","x":"2.2cm","width":"29.47cm","align":"left","y":"3cm","height":"1.2cm","size":"16pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Experimental Designs","x":"2.2cm","width":"29.47cm","align":"left","y":"4.6cm","height":"3.4cm","size":"48pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[1]","type":"shape","props":{"preset":"rect","fill":"4ad6e6","line":"none","x":"2.2cm","y":"8.399999999999999cm","width":"6cm","height":"0.12cm"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Testing whether a program truly causes the change we observe","x":"2.2cm","width":"29.47cm","align":"left","y":"9.299999999999999cm","height":"2.4cm","size":"22pt","italic":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Subject 714 · Project Development & Evaluation · Chapter 5 · Topic 5.1","x":"2.2cm","width":"29.47cm","align":"left","y":"12.299999999999999cm","height":"1.0cm","size":"15pt","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Reporter: Rosemarie S. Rizon","x":"2.2cm","width":"29.47cm","align":"left","y":"13.399999999999999cm","height":"1.0cm","size":"15pt","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Orientation","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Where my topic sits","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[2]","type":"picture","props":{"src":"assets/research_s2_0.png","x":"4.26cm","y":"5.50cm","width":"25.34cm","height":"6.34cm"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Chapter 5 surveys many methods. This report covers only the first — 5.1, the strongest design for proving cause.","x":"2.2cm","width":"29.47cm","align":"center","y":"12.09cm","height":"1.4cm","size":"14pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"What this report will cover","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  What an experimental design is","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  The RCT — the strongest form, step by step","x":"2.2cm","width":"29.47cm","align":"left","y":"5.80cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  Its building blocks — randomizing, control, pre–post","x":"2.2cm","width":"29.47cm","align":"left","y":"7.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  Validity, strengths, limits, and when to use it","x":"2.2cm","width":"29.47cm","align":"left","y":"8.80cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"The question it answers","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"Did our program cause the improvement — or would it have happened anyway? Experimental design is how we tell the difference.","x":"2.2cm","width":"29.47cm","align":"left","y":"4.300000000000001cm","height":"13.25cm","size":"26pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Defining the construct","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"What an experimental design is","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Experimental design","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.2cm","size":"24pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"A research method that tests cause and effect by changing one thing on purpose and comparing the results against a group that was left unchanged.\nIn plain terms: try the program on one group, not on another, and see what differs.","x":"2.2cm","width":"29.47cm","align":"left","y":"6.60cm","height":"2.8cm","size":"19pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"5.1","x":"2.2cm","width":"29.47cm","align":"left","y":"2.4cm","height":"4cm","size":"96pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"The heart of the topic","x":"2.2cm","width":"29.47cm","align":"left","y":"8.6cm","height":"1.0cm","size":"16pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"The Randomized Controlled Trial","x":"2.2cm","width":"29.47cm","align":"left","y":"10.0cm","height":"4cm","size":"40pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"How an RCT works","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[7]","type":"picture","props":{"src":"assets/research_s7_0.png","x":"4.26cm","y":"4.50cm","width":"25.34cm","height":"6.59cm"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"Random assignment makes the two groups alike — so any difference at the end points to the program.","x":"2.2cm","width":"29.47cm","align":"center","y":"11.34cm","height":"1.4cm","size":"14pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"Building block 1","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"Why assign at random?","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"Random assignment spreads every hidden difference — age, ability, background — evenly across both groups, so the only real difference left is the program itself.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Building block 2","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"The control group","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Control group","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.2cm","size":"24pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"A comparison group that does not receive the program, kept alongside the treatment group.\nIt shows what would have happened without the program — the \"what if we did nothing\" picture.","x":"2.2cm","width":"29.47cm","align":"left","y":"6.60cm","height":"2.8cm","size":"19pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Building block 3","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Pre–post measurement","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[10]","type":"picture","props":{"src":"assets/research_s10_0.png","x":"4.26cm","y":"5.50cm","width":"25.34cm","height":"5.07cm"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Measuring before and after lets us see the change clearly.","x":"2.2cm","width":"29.47cm","align":"center","y":"10.82cm","height":"1.4cm","size":"14pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"A school example","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[11]","type":"shape","props":{"preset":"roundRect","fill":"13203f","line":"none","x":"2.2cm","y":"4.30cm","width":"29.47cm","height":"13.25cm"}},{"op":"add","path":"/slide[11]","type":"shape","props":{"preset":"rect","fill":"4ad6e6","line":"none","x":"2.2cm","y":"4.30cm","width":"0.18cm","height":"13.25cm"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Testing a reading program","x":"2.80cm","width":"28.27cm","align":"left","y":"4.80cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Take 100 pupils. Randomly split them: 50 join the new reading program, 50 keep the usual lessons. Test everyone before and after. If the program group improves more, the program likely caused it.","x":"2.80cm","width":"28.27cm","align":"left","y":"5.90cm","height":"11.25cm","size":"21pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"5.1","x":"2.2cm","width":"29.47cm","align":"left","y":"2.4cm","height":"4cm","size":"96pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Judging the study","x":"2.2cm","width":"29.47cm","align":"left","y":"8.6cm","height":"1.0cm","size":"16pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Internal & External Validity","x":"2.2cm","width":"29.47cm","align":"left","y":"10.0cm","height":"4cm","size":"40pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Internal validity","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Is the result real?","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Are we sure the program caused the change, and not something else? Strong internal validity means the result is real, not a fluke.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"External validity","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Does it hold elsewhere?","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Would the result hold true elsewhere, with other people or in other places? Strong external validity means it generalizes beyond this one study.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"Things that can weaken validity","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"◆  Dropouts","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"     People leaving the study can unbalance the groups.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"◆  Too small a sample","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"     A few people can't represent everyone.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"◆  Spillover","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"     The control group accidentally gets some of the program.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"Why this design is the strongest","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"◆  Isolates the cause","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"     The control group rules out other explanations.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"◆  Removes bias","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"     Random assignment keeps the groups fair.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"◆  Trusted evidence","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"     Its results carry the most weight in evaluation.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"When it is hard to use","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[17]","type":"shape","props":{"preset":"roundRect","fill":"13203f","line":"none","x":"2.2cm","y":"4.30cm","width":"29.47cm","height":"13.25cm"}},{"op":"add","path":"/slide[17]","type":"shape","props":{"preset":"rect","fill":"4ad6e6","line":"none","x":"2.2cm","y":"4.30cm","width":"0.18cm","height":"13.25cm"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"Practical & ethical limits","x":"2.80cm","width":"28.27cm","align":"left","y":"4.80cm","height":"0.9cm","size":"14pt","bold":"true","color":"9a8cff","font":"Trebuchet MS"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"Sometimes we cannot randomly withhold a program — it may be unfair to deny help, or simply impractical. In those cases researchers turn to other designs (5.2 onward).","x":"2.80cm","width":"28.27cm","align":"left","y":"5.90cm","height":"11.25cm","size":"21pt","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"When to choose an experimental design","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  You need proof of cause","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     Not just that two things move together.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  You can assign at random","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     Fairly and ethically.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  The stakes are high","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"eef2fb","font":"Trebuchet MS"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     A big decision rests on the evidence.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"0a1124"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Key takeaways","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[19]","type":"shape","props":{"preset":"rect","fill":"9a8cff","line":"none","x":"2.20cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Purpose","x":"2.70cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"4ad6e6","font":"Trebuchet MS"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Prove a program truly causes a result.","x":"2.70cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"9fb0d4","font":"Trebuchet MS"}},{"op":"add","path":"/slide[19]","type":"shape","props":{"preset":"rect","fill":"9a8cff","line":"none","x":"17.43cm","y":"4.