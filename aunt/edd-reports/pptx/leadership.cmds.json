[{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Cebu Technological University · Doctor of Education (EdD)","x":"2.2cm","width":"29.47cm","align":"left","y":"3cm","height":"1.2cm","size":"16pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Principles of Ethics in Educational Administration","x":"2.2cm","width":"29.47cm","align":"left","y":"4.6cm","height":"3.4cm","size":"48pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[1]","type":"shape","props":{"preset":"rect","fill":"e8b54b","line":"none","x":"2.2cm","y":"8.399999999999999cm","width":"6cm","height":"0.12cm"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"The core principles that guide fair, honest decisions in running a school","x":"2.2cm","width":"29.47cm","align":"left","y":"9.299999999999999cm","height":"2.4cm","size":"22pt","italic":"true","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Subject 703 · Educational Leadership · Chapter 11 · Topic 11.2","x":"2.2cm","width":"29.47cm","align":"left","y":"12.299999999999999cm","height":"1.0cm","size":"15pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[1]","type":"textbox","props":{"text":"Reporter: Rosemarie S. Rizon","x":"2.2cm","width":"29.47cm","align":"left","y":"13.399999999999999cm","height":"1.0cm","size":"15pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Orientation","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Where my topic sits","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[2]","type":"picture","props":{"src":"assets/leadership_s2_0.png","x":"4.26cm","y":"5.50cm","width":"25.34cm","height":"5.83cm"}},{"op":"add","path":"/slide[2]","type":"textbox","props":{"text":"Chapter 11 has several topics. This report covers only 11.2 — the principles that turn values into ethical practice.","x":"2.2cm","width":"29.47cm","align":"center","y":"11.58cm","height":"1.4cm","size":"14pt","italic":"true","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"What this report will cover","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  What ethical principles are","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  Why principles, not just rules","x":"2.2cm","width":"29.47cm","align":"left","y":"5.80cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  The core principles, one by one","x":"2.2cm","width":"29.47cm","align":"left","y":"7.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/slide[3]","type":"textbox","props":{"text":"◆  How they work in practice, and why they matter","x":"2.2cm","width":"29.47cm","align":"left","y":"8.80cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"Defining the construct","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"What ethical principles are","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"Ethical principles","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.2cm","size":"24pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[4]","type":"textbox","props":{"text":"The agreed standards of right conduct that guide how a leader makes decisions and treats people — especially when the choice is difficult.\nIn plain terms: the rules of \"doing right\" that a school administrator lives by.","x":"2.2cm","width":"29.47cm","align":"left","y":"6.60cm","height":"2.8cm","size":"19pt","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"From values to principles to practice","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[5]","type":"picture","props":{"src":"assets/leadership_s5_0.png","x":"4.26cm","y":"4.50cm","width":"25.34cm","height":"5.07cm"}},{"op":"add","path":"/slide[5]","type":"textbox","props":{"text":"Principles are the bridge between what we believe and what we do.","x":"2.2cm","width":"29.47cm","align":"center","y":"9.82cm","height":"1.4cm","size":"14pt","italic":"true","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"Why principles, not just rules","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[6]","type":"textbox","props":{"text":"Rules cannot cover every situation. Principles give a leader a steady way to decide what is right even when no rule fits the case in front of them.","x":"2.2cm","width":"29.47cm","align":"left","y":"4.300000000000001cm","height":"13.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"11.2","x":"2.2cm","width":"29.47cm","align":"left","y":"2.4cm","height":"4cm","size":"96pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"The heart of the topic","x":"2.2cm","width":"29.47cm","align":"left","y":"8.6cm","height":"1.0cm","size":"16pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[7]","type":"textbox","props":{"text":"The Core Ethical Principles","x":"2.2cm","width":"29.47cm","align":"left","y":"10.0cm","height":"4cm","size":"40pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"Principle 1","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"Integrity & honesty","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[8]","type":"textbox","props":{"text":"Be truthful and consistent; keep your word. What you say and what you do should match.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Principle 2","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Fairness & justice","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[9]","type":"textbox","props":{"text":"Treat everyone equally; decide without favoritism, and give each person what is due to them.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Principle 3","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Respect for persons","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[10]","type":"textbox","props":{"text":"Honor the dignity of every person — each student and staff member — in how you speak and decide.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Principle 4","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Accountability","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[11]","type":"textbox","props":{"text":"Own your decisions and answer for their results — do not pass the blame when things go wrong.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Principle 5","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Confidentiality","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[12]","type":"textbox","props":{"text":"Protect private information about students and staff; share it only when it is right and necessary.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Principle 6","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Service & the common good","x":"2.2cm","width":"29.47cm","align":"left","y":"2.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[13]","type":"textbox","props":{"text":"Put the welfare of learners and the community above personal interest. The role is a trust, not a privilege.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.300000000000001cm","height":"12.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"The principles at a glance","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"2.20cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Integrity","x":"2.70cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Be truthful and consistent.","x":"2.70cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[14]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"17.43cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Fairness","x":"17.93cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"No favoritism; justice for all.","x":"17.93cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[14]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"2.20cm","y":"7.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Respect","x":"2.70cm","width":"13.73cm","align":"left","y":"7.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Honor every person's dignity.","x":"2.70cm","width":"13.73cm","align":"left","y":"8.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[14]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"17.43cm","y":"7.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Accountability","x":"17.93cm","width":"13.73cm","align":"left","y":"7.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Own your decisions.","x":"17.93cm","width":"13.73cm","align":"left","y":"8.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[14]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"2.20cm","y":"10.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Confidentiality","x":"2.70cm","width":"13.73cm","align":"left","y":"10.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Guard private information.","x":"2.70cm","width":"13.73cm","align":"left","y":"11.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[14]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"17.43cm","y":"10.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"Service","x":"17.93cm","width":"13.73cm","align":"left","y":"10.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[14]","type":"textbox","props":{"text":"The common good comes first.","x":"17.93cm","width":"13.73cm","align":"left","y":"11.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"A principle in action","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[15]","type":"shape","props":{"preset":"roundRect","fill":"2c1c30","line":"none","x":"2.2cm","y":"4.30cm","width":"29.47cm","height":"13.25cm"}},{"op":"add","path":"/slide[15]","type":"shape","props":{"preset":"rect","fill":"e8b54b","line":"none","x":"2.2cm","y":"4.30cm","width":"0.18cm","height":"13.25cm"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"A hard choice","x":"2.80cm","width":"28.27cm","align":"left","y":"4.80cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[15]","type":"textbox","props":{"text":"A relative applies for a teaching post and is not the most qualified.\n\nThe principles of fairness and integrity say: choose the best candidate, openly and on merit — even when it is personally uncomfortable.","x":"2.80cm","width":"28.27cm","align":"left","y":"5.90cm","height":"11.25cm","size":"21pt","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"A second hard choice","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[16]","type":"shape","props":{"preset":"roundRect","fill":"2c1c30","line":"none","x":"2.2cm","y":"4.30cm","width":"29.47cm","height":"13.25cm"}},{"op":"add","path":"/slide[16]","type":"shape","props":{"preset":"rect","fill":"e8b54b","line":"none","x":"2.2cm","y":"4.30cm","width":"0.18cm","height":"13.25cm"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"Confidentiality vs. pressure","x":"2.80cm","width":"28.27cm","align":"left","y":"4.80cm","height":"0.9cm","size":"14pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[16]","type":"textbox","props":{"text":"A staff member shares something private in confidence. Others press you to repeat it.\n\nConfidentiality and respect say: protect it — share only what is truly necessary, and only with those who must know.","x":"2.80cm","width":"28.27cm","align":"left","y":"5.90cm","height":"11.25cm","size":"21pt","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"When principles seem to collide","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[17]","type":"textbox","props":{"text":"Sometimes two principles pull in different directions. The leader weighs them honestly, chooses the one that best serves people and the common good, and can explain the reason openly.","x":"2.2cm","width":"29.47cm","align":"left","y":"4.300000000000001cm","height":"13.25cm","size":"26pt","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"Why these principles matter","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  Trust","x":"2.2cm","width":"29.47cm","align":"left","y":"4.30cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     People trust a leader whose decisions are fair and honest.","x":"2.2cm","width":"29.47cm","align":"left","y":"5.30cm","height":"1.0cm","size":"16pt","italic":"true","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  Consistency","x":"2.2cm","width":"29.47cm","align":"left","y":"6.90cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     Principles keep decisions steady from one case to the next.","x":"2.2cm","width":"29.47cm","align":"left","y":"7.90cm","height":"1.0cm","size":"16pt","italic":"true","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"◆  Good example","x":"2.2cm","width":"29.47cm","align":"left","y":"9.50cm","height":"1.0cm","size":"21pt","bold":"true","color":"f5eef2","font":"Calibri"}},{"op":"add","path":"/slide[18]","type":"textbox","props":{"text":"     A school learns ethics from how its leaders behave.","x":"2.2cm","width":"29.47cm","align":"left","y":"10.50cm","height":"1.0cm","size":"16pt","italic":"true","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Key takeaways","x":"2.2cm","width":"29.47cm","align":"left","y":"1.6cm","height":"2.4cm","size":"32pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[19]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"2.20cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"What","x":"2.70cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Ethical principles are the standards of right conduct.","x":"2.70cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[19]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"17.43cm","y":"4.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"The core","x":"17.93cm","width":"13.73cm","align":"left","y":"4.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Integrity, fairness, respect, accountability.","x":"17.93cm","width":"13.73cm","align":"left","y":"5.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[19]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"2.20cm","y":"7.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Also","x":"2.70cm","width":"13.73cm","align":"left","y":"7.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Confidentiality and service to the common good.","x":"2.70cm","width":"13.73cm","align":"left","y":"8.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/slide[19]","type":"shape","props":{"preset":"rect","fill":"c98bd0","line":"none","x":"17.43cm","y":"7.30cm","width":"0.12cm","height":"2.4cm"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"Why","x":"17.93cm","width":"13.73cm","align":"left","y":"7.30cm","height":"1.0cm","size":"20pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[19]","type":"textbox","props":{"text":"They build trust, consistency, and a good example.","x":"17.93cm","width":"13.73cm","align":"left","y":"8.30cm","height":"1.7cm","size":"16pt","color":"c4abc6","font":"Calibri"}},{"op":"add","path":"/","type":"slide","props":{"layout":"blank","background":"1c0f1f"}},{"op":"add","path":"/slide[20]","type":"textbox","props":{"text":"703 · Chapter 11 · Topic 11.2","x":"2.2cm","width":"29.47cm","align":"left","y":"3cm","height":"1.2cm","size":"16pt","bold":"true","color":"c98bd0","font":"Calibri"}},{"op":"add","path":"/slide[20]","type":"textbox","props":{"text":"Thank you","x":"2.2cm","width":"29.47cm","align":"left","y":"4.6cm","height":"3.4cm","size":"48pt","bold":"true","color":"e8b54b","font":"Georgia"}},{"op":"add","path":"/slide[20]","type":"shape","props":{"preset":"rect","fill":"e8b54b","line":"none","x":"2.2cm","y":"8.399999999999999cm","width":"6cm","height":"0.12cm"}},{"op":"add","path":"/slide[20]","type":"textbox","props":{"text":"Leading by principle.","x":"2.2cm","width":"29.47cm","align":"left","y":"9.299999999999999cm","height":"2.4cm","size":"22pt","italic":"true","color":"f5eef2","font":"Georgia"}},{"op":"add","path":"/slide[20]","type":"textbox","props":{"text":"Reporter: Rosemarie S. Rizon","x":"2.2cm","width":"29.47cm","align":"left","y":"12.299999999999999cm","height":"1.0cm","size":"15pt","color":"c4abc6","font":"Calibri"}}]